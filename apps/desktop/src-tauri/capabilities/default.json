{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri/schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main FluxStudio window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-rename",
    "fs:allow-remove",
    "updater:default",
    "deep-link:default"
  ]
}
