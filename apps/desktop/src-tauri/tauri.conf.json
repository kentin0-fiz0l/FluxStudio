{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "FluxStudio",
  "version": "0.1.0",
  "identifier": "art.fluxstudio.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FluxStudio",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.fluxstudio.art https://*.sentry.io http://localhost:3001 http://localhost:4000 ws://localhost:3001 ws://localhost:4000; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": null,
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "fileAssociations": [
      {
        "ext": ["flux"],
        "mimeType": "application/x-fluxstudio",
        "description": "FluxStudio Project File"
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["web+fluxstudio"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/fluxstudio/fluxstudio-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    },
    "sentry": {
      "dsn": "",
      "debug": false
    }
  }
}
